# vistaar-backend environment. Copy to .env for local dev.
# On the server these values come from the GitLab File variable APP_ENV.

# MongoDB (self-hosted replica set). Local dev can point at any Mongo.
MONGODB_URI=mongodb://127.0.0.1:27017/vistaar
DB_NAME=vistaar
# The schools dataset collection the /api/schools search reads from.
COLLECTION_NAME=schools

PORT=3001
